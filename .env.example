# Required for scenario-1 (Claude proposes the patch).
ANTHROPIC_API_KEY=

# Override the model the orchestrator calls. Defaults to claude-opus-4-7.
# VERIFIER_MODEL=claude-sonnet-4-6

# Real verification: point mirrord at the target deployment in your staging cluster.
# Without these, the runner emits SIMULATED metrics so the scaffold stays runnable.
# MIRRORD_BIN=mirrord
# MIRRORD_TARGET=deploy/checkout
# MIRRORD_NAMESPACE=staging

# Required only if you wire up DatadogEventPoster.
# DATADOG_API_KEY=

# Required only if you wire up GitHubPRCommentPoster.
# GITHUB_TOKEN=

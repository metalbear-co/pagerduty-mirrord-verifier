# PagerDuty REST API key (org-scoped, non-read-only). Verifier uses this to
# post the proof bundle as a note on the originating incident.
PAGERDUTY_REST_API_KEY=

# PagerDuty Webhook V3 signing secret. Verifier verifies each incoming
# webhook's HMAC-SHA256 against this. Set the same value in PD → Integrations
# → Generic Webhooks (V3) → your subscription.
PAGERDUTY_WEBHOOK_SIGNING_SECRET=

# Email the note is posted from. Any user in the PD account works. Defaults to
# verifier@metalbear.com.
# PAGERDUTY_FROM_EMAIL=

# Anthropic key for the bridge (Claude call that turns the AI-SRE
# recommendation into a code patch).
ANTHROPIC_API_KEY=

# Override the model the bridge calls. Defaults to claude-opus-4-7.
# VERIFIER_MODEL=claude-sonnet-4-6

# Real verification: point mirrord at the target deployment in your staging cluster.
# Without these, the runner emits SIMULATED metrics so the scaffold stays runnable.
# MIRRORD_BIN=mirrord
# MIRRORD_TARGET=deploy/checkout
# MIRRORD_NAMESPACE=staging
